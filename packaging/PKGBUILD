# Maintainer: Andrea Coi <acandry90@gmail.com>
pkgname='notetux++'
pkgver=1.0.0
pkgrel=1
pkgdesc='Feature-rich text editor for Linux (GTK3 port of Notepad++)'
arch=('x86_64')
url='https://github.com/andreacos/notetux'
license=('GPL-3.0-or-later')
depends=(
    'gtk3'
    'glib2'
    'gcc-libs'
)
makedepends=(
    'cmake'
    'pkgconf'
    'gcc'
)
optdepends=(
    'enchant: spell checking support'
)
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/andreacos/notetux/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

# The GitHub archive extracts as the repo slug (notetux), not notetux++
_srcdir="notetux-${pkgver}"

prepare() {
    # Tolerate either notetux-<ver> or notetux++-<ver> depending on repo name
    if [ ! -d "${srcdir}/${_srcdir}" ]; then
        _srcdir="${pkgname}-${pkgver}"
    fi
}

build() {
    cmake -B "${srcdir}/build" -S "${srcdir}/${_srcdir}" \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DRESOURCES_DIR=/usr/share/notetux
    cmake --build "${srcdir}/build" --parallel "$(nproc)"
}

package() {
    # Binary
    install -Dm755 "${srcdir}/build/notetux++" \
        "${pkgdir}/usr/bin/notetux++"

    # Resources tree
    install -d "${pkgdir}/usr/share/notetux"
    cp -r "${srcdir}/${_srcdir}/resources/." "${pkgdir}/usr/share/notetux/"

    # Pixmap icon
    install -Dm644 "${srcdir}/${_srcdir}/resources/icons/standard/icon.png" \
        "${pkgdir}/usr/share/pixmaps/notetux++.png"

    # .desktop file
    install -Dm644 "${srcdir}/${_srcdir}/packaging/notetux++.desktop" \
        "${pkgdir}/usr/share/applications/notetux++.desktop"

    # License
    install -Dm644 "${srcdir}/${_srcdir}/LICENSE" \
        "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
